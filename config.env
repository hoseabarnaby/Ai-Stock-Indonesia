# Crypto: CoinGecko langsung. CRYPTO_SYMBOLS kosong = AI pilih universe otomatis.
CRYPTO_PROVIDER=coingecko
CRYPTO_UNIVERSE_MODE=ai
CRYPTO_SYMBOLS=
CRYPTO_UNIVERSE_LIMIT=60
CRYPTO_SIGNAL_LIMIT=24
MIN_CRYPTO_VOLUME_USD=10000000
COINGECKO_API_KEY=

# Forex reference rates
FOREX_PROVIDER=frankfurter
FOREX_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,USDCHF,NZDUSD

# Refresh
LIVE_PRICE_POLL_SECONDS=15
SIGNAL_VALIDATE_POLL_SECONDS=30

# AI reasoning optional
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

PUBLIC_SIGNAL_SAFETY_MODE=true

# Market Insight news feed
CRYPTO_NEWS_ENABLED=true
CRYPTO_NEWS_RSS_URLS=https://cointelegraph.com/rss,https://www.coindesk.com/arc/outboundfeeds/rss/
CRYPTO_NEWS_LIMIT=8

# Chart
CHART_PROVIDER=coingecko
CHART_DAYS=1

# Chart
CHART_PROVIDER=coingecko
CHART_MODE=ohlc
CHART_DAYS=1

# Global stable signal mode
SIGNAL_STABILITY_MODE=supabase
SIGNAL_AUTO_REPLACE_INVALID=true
SIGNAL_STABLE_MINUTES=240
